# ─── AUTOPILOT SCALPER BOT — Environment Variables ───
# Copy this to .env and fill in your values
# On Railway: paste these into the Variables tab (not as a file)

# ── TELEGRAM (required for alerts) ──────────────────
# Step 1: Message @BotFather on Telegram → /newbot → copy token
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Step 2: Message @userinfobot on Telegram → copy your chat ID
TELEGRAM_CHAT_ID=your_chat_id_here

# ── TRADING MODE ─────────────────────────────────────
# true  = paper trading (no real money, safe to start)
# false = live trading (real money via Jupiter)
PAPER_MODE=true

# ── POSITION SIZING ──────────────────────────────────
POSITION_SIZE_USD=100
STARTING_BALANCE=1000
MAX_POSITIONS=4

# ── TIMING ───────────────────────────────────────────
SCAN_INTERVAL_MS=120000   # 2 minutes = 120000ms
MAX_HOLD_MS=1800000       # 30 minutes max hold

# ── EXIT RULES ───────────────────────────────────────
TRAIL_PCT=20              # trailing stop %
STOP_LOSS_PCT=25          # hard stop loss %

# ── LIVE TRADING (only needed when PAPER_MODE=false) ─
# WARNING: Never commit your private key to git
# Generate a dedicated trading wallet — never use main wallet
WALLET_PRIVATE_KEY=your_base58_private_key_here
